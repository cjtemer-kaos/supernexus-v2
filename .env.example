# SuperNEXUS v2 - Configuracion de Entorno
# Copia este archivo a .env y completa con tus valores

# ═══════════════════════════════════════════════════════════
# CONFIGURACION BASICA
# ═══════════════════════════════════════════════════════════

# Directorio del proyecto (donde instalaste SuperNEXUS)
NEXUS_PROJECT_DIR=${HOME}/supernexus-v2

# Puerto del API (default: 9001)
NEXUS_API_PORT=9001

# ═══════════════════════════════════════════════════════════
# OLLAMA (Modelos Locales)
# ═══════════════════════════════════════════════════════════

# URL de Ollama (local por defecto)
OLLAMA_URL=http://localhost:11434

# Modelos recomendados (se descargan automaticamente):
#   qwen2.5:0.5b       - Chat rapido
#   qwen2.5-coder:7b   - Programacion
#   deepseek-r1:8b     - Razonamiento
#   nemotron-3-nano:4b - Chat ligero
#   qwen2.5vl:7b       - Vision (opcional)

# ═══════════════════════════════════════════════════════════
# API KEYS (Opcionales - para modelos cloud)
# ═══════════════════════════════════════════════════════════

# OpenAI (GPT-4o, etc)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google Gemini
GOOGLE_API_KEY=

# Groq (inferencia rapida)
GROQ_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# OpenCode Zen (modelos cloud gratuitos y premium)
# Modelos gratuitos: deepseek-v4-flash-free, minimax-m2.5-free, nemotron-3-super-free
# Modelos premium: claude-sonnet-4-6, qwen3.6-plus, gpt-5.5, etc.
# Obtener key en: https://opencode.ai/auth
OPENCODE_API_KEY=

# ═══════════════════════════════════════════════════════════
# NODOS REMOTOS (Opcional - para computacion distribuida)
# ═══════════════════════════════════════════════════════════

# IP del nodo remoto (Linux con GPU recomendado)
REMOTE_NODE_IP=
REMOTE_NODE_PORT=22
REMOTE_NODE_USER=
REMOTE_NODE_PASSWORD=

# ═══════════════════════════════════════════════════════════
# BASE DE DATOS
# ═══════════════════════════════════════════════════════════

# Ruta de la base de datos de memoria
NEXUS_DB_PATH=${NEXUS_PROJECT_DIR}/memory/nexus_memory.db

# ═══════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════

# Nivel de log: DEBUG, INFO, WARNING, ERROR
NEXUS_LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════
# CONFIGURACION QWEN CLI + FREEQWENAPI
# ═══════════════════════════════════════════════════════════
QWEN_AUTH_TYPE=openai
QWEN_API_KEY=free-qwen-key
QWEN_BASE_URL=http://localhost:3264/api
QWEN_MODEL=qwen3-coder-plus

# ═══════════════════════════════════════════════════════════
# INTEGRACIONES EXTERNAS (Opcionales)
# Solo configura las que vayas a usar
# ═══════════════════════════════════════════════════════════

# ComfyUI — Generación de imágenes
# COMFYUI_OUTPUT_DIR=C:/ComfyUI/output

# Open CoDesign — Herramienta de diseño AI
# OPEN_CODESIGN_PATH=C:/tools/open-codesign

# Bolt.diy — Interfaz local AI dev
# BOLT_DIY_PATH=C:/tools/bolt_diy

# Agent Zero — Agente autónomo (Docker)
# AGENT_ZERO_PATH=C:/tools/agent-zero

# ═══════════════════════════════════════════════════════════
# VOICE (JARVIS)
# ═══════════════════════════════════════════════════════════

# Modelo para JARVIS (default: qwen3.5:4b)
JARVIS_MODEL=qwen3.5:4b

# Puerto JARVIS API
JARVIS_PORT=9039

