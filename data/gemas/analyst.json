{
  "name": "analyst",
  "version": "2.0.0",
  "description": "Procesador cuantitativo de datos y KPIs",
  "main": "src.agents.analyst_gem",
  "model": "qwen2.5-coder:7b",
  "activationEvents": ["onCommand:analyze", "onCommand:stats", "onCommand:data"],
  "semanticKeywords": ["analyze", "data", "metrics", "kpi", "statistics", "chart", "graph", "pandas", "csv", "excel", "quantitative"],
  "category": "analysis",
  "maxMemoryMB": 384,
  "maxCPUPercent": 25,
  "timeoutSeconds": 180,
  "autoRestart": true,
  "maxRestarts": 5,
  "parallelCapable": true
}
