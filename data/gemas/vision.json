{
  "name": "vision",
  "version": "2.0.0",
  "description": "Captura de pantalla, analisis de imagenes y OCR",
  "main": "src.agents.vision_gem",
  "model": "qwen2.5vl:2b",
  "activationEvents": ["onCommand:screenshot", "onCommand:vision", "onCommand:ocr"],
  "semanticKeywords": ["screenshot", "screen", "vision", "image", "ocr", "read", "capture", "visual", "pixel", "mouse", "keyboard"],
  "category": "multimedia",
  "maxMemoryMB": 384,
  "maxCPUPercent": 20,
  "timeoutSeconds": 60,
  "autoRestart": true,
  "maxRestarts": 5,
  "parallelCapable": false
}
