{
  "name": "security",
  "version": "2.0.0",
  "description": "Auditor estatico de codigo contra RCE, SQLi, SSRF y secretos",
  "main": "src.agents.security_gem",
  "model": "deepseek-r1:8b",
  "activationEvents": ["onCommand:audit", "onCommand:security", "onCommand:scan"],
  "semanticKeywords": ["security", "audit", "vulnerability", "rce", "sqli", "ssrf", "secret", "encrypt", "auth", "scan"],
  "category": "security",
  "maxMemoryMB": 256,
  "maxCPUPercent": 15,
  "timeoutSeconds": 120,
  "autoRestart": true,
  "maxRestarts": 5,
  "parallelCapable": true
}
