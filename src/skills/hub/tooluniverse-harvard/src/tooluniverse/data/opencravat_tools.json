            {
                "category": "annotator"
            }
        ],
        "return_schema": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "name": {"type": "string"},
                    "title": {"type": "string"},
                    "description": {"type": "string"},
                    "type": {"type": "string"}
                }
            }
        },
        "label": ["OpenCRAVAT", "Annotators", "Registry"],
        "metadata": {
            "tags": ["variant_annotation", "annotator_registry", "metadata"],
